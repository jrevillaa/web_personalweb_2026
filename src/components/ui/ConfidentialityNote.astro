---
interface Props {
    text: string;
}
const { text } = Astro.props;
---

<div class="confidentiality-note">
    <i class="fa-solid fa-circle-info icon"></i>
    <p>{text}</p>
</div>

<style>
    .confidentiality-note {
        display: flex;
        align-items: center;
        gap: 1rem;
        background-color: var(--bg-dark-soft);
        border: 1px solid var(--border-dark-soft);
        padding: 1rem 1.5rem;
        border-radius: 8px;
        margin: 2rem auto;
        max-width: 800px;
        color: var(--color-text-light);
        font-size: 0.95rem;
        line-height: 1.5;
    }

    /* Dark mode support if applicable, assuming global classes or media query */
    @media (prefers-color-scheme: dark) {
        .confidentiality-note {
            background-color: var(--bg-light-soft);
            border-color: var(--border-light-soft);
            color: var(--text-disabled);
        }
    }

    .icon {
        font-size: 1.2rem;
        color: var(--accent-info);
        flex-shrink: 0;
    }
</style>
